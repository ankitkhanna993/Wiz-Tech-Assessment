<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wiz Exercise - Todo App</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 600px; margin: 50px auto; padding: 0 20px; }
    h1 { color: #1a73e8; }
    .badge { background: #1a73e8; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.75em; }
    form input[type=text] { width: 70%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; }
    form button { padding: 8px 16px; background: #1a73e8; color: white; border: none; border-radius: 4px; cursor: pointer; }
    ul { list-style: none; padding: 0; }
    li { display: flex; align-items: center; padding: 10px; border-bottom: 1px solid #eee; }
    li.completed span { text-decoration: line-through; color: #888; }
    li span { flex: 1; margin-left: 8px; }
    .del-btn { background: #e53935; color: white; border: none; border-radius: 4px; padding: 4px 10px; cursor: pointer; }
  </style>
</head>
<body>
  <h1>📝 Wiz Todo App <span class="badge">MongoDB</span></h1>
  <form action="/todos" method="POST">
    <input type="text" name="title" placeholder="Add a new todo..." required />
    <button type="submit">Add</button>
  </form>
  <hr/>
  <p><strong><%= todos.length %></strong> todo(s) in MongoDB</p>
  <ul>
    <% todos.forEach(todo => { %>
      <li class="<%= todo.completed ? 'completed' : '' %>">
        <form action="/todos/<%= todo._id %>/toggle" method="POST" style="margin:0">
          <input type="checkbox" <%= todo.completed ? 'checked' : '' %> onchange="this.form.submit()"/>
        </form>
        <span><%= todo.title %></span>
        <button class="del-btn" onclick="deleteTodo('<%= todo._id %>')">Delete</button>
      </li>
    <% }) %>
  </ul>
  <hr/>
  <p>
    <a href="/validate">Validate wizexercise.txt</a> |
    <a href="/health">Health Check</a> |
    <a href="/api/todos">API</a>
  </p>
  <script>
    function deleteTodo(id) {
      fetch('/todos/' + id, { method: 'DELETE' })
        .then(() => location.reload());
    }
  </script>
</body>
</html>
